# ══════════════════════════════════════════════════════════════
#  مثال على متغيرات البيئة المطلوبة
#  انسخ هذا الملف وسمّه .env ثم عدّل القيم
# ══════════════════════════════════════════════════════════════

# Django Secret Key — أنشئ مفتاحاً جديداً بـ: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=your-secret-key-here

# إعدادات بيئة Django
# للتطوير:       core.settings.dev
# للتشغيل الداخلي: core.settings.internal
# للإنتاج:       core.settings.prod
DJANGO_SETTINGS_MODULE=core.settings.internal

# عنوان IP الخادم (مطلوب لـ internal.py) — أضف عنوان جهاز الخادم
ALLOWED_HOSTS=192.168.1.100

# للإنتاج فقط (prod.py)
# DB_NAME=international_db
# DB_USER=postgres
# DB_PASSWORD=your-db-password
# DB_HOST=localhost
# DB_PORT=5432
# CORS_ORIGINS=https://yourdomain.com
