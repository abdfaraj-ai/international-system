[Unit]
Description=International System (Django + Daphne ASGI)
After=network.target postgresql.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/intl-system
EnvironmentFile=/opt/intl-system/.env
ExecStart=/opt/intl-system/.venv/bin/daphne -b 127.0.0.1 -p 8000 core.asgi:application
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
