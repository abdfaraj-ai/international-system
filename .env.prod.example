# ══════════════════════════════════════════════════════════════
#  .env.prod.example — قالب متغيرات بيئة الإنتاج
#  انسخ هذا الملف إلى .env.prod وعبِّئ القيم الحقيقية
#  تحذير: لا ترفع .env.prod إلى Git أبداً
# ══════════════════════════════════════════════════════════════

# ── Django ────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=core.settings.prod

# أنشئ مفتاحاً جديداً:
# python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET_KEY

# ── النطاق ────────────────────────────────────────────────────
ALLOWED_HOSTS=your-domain.com,www.your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ── قاعدة البيانات PostgreSQL ─────────────────────────────────
DB_NAME=intl_system_db
DB_USER=intl_user
DB_PASSWORD=CHANGE_ME_TO_STRONG_DB_PASSWORD
DB_HOST=db
DB_PORT=5432
# prefer = يستخدم SSL إن توفر | require = SSL إلزامي (إذا كان DB على سيرفر منفصل)
DB_SSLMODE=prefer

# ── البريد الإلكتروني ─────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ── Google OAuth (اختياري) ────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── OpenAI Whisper API (للتعرف على الصوت في تطبيق الموبايل) ──
# احصل على المفتاح من: platform.openai.com/api-keys
# إذا كان فارغاً يُستخدم Whisper المحلي كاحتياط
OPENAI_API_KEY=sk-...

# ── Groq API (شات بوت البوابة الخارجية) ─────────────────────
# احصل على المفتاح من: console.groq.com/keys
GROQ_API_KEY=gsk_...

# ── Anthropic (Claude AI) ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Flutter App Key ───────────────────────────────────────────
# أنشئ مفتاحاً عشوائياً: python -c "import secrets; print(secrets.token_urlsafe(32))"
FLUTTER_API_KEY=CHANGE_ME_TO_RANDOM_KEY

# ── ZKTeco Fingerprint Device ─────────────────────────────────
ZK_IP=192.168.1.201
ZK_PORT=4370
